# Copy this file to .env before deployment and change all passwords/tokens.
# The .env file is intentionally ignored by Git.

INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-influxdb-password
INFLUXDB_ORG=pv-monitoring
INFLUXDB_BUCKET=pv_data
INFLUXDB_ADMIN_TOKEN=change-me-influxdb-token

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=pv_system

MQTT_BROKER_HOST=your-emqx-cloud-host
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=nodered_subscriber_001
